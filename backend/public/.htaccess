# Bangron Studio — public directory
# Only serve static files directly, route everything else to index.php

RewriteEngine On

# Serve static files from build/ directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Block access to sensitive paths
RewriteRule ^storage/ - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^var/ - [F,L]

# Route all API + page requests to index.php (Flight handles everything)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>