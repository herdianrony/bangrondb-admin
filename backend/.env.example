DB_PATH=./storage/data
ENCRYPTION_KEY=change-this-to-32+char-super-secret-key!!

# JWT
JWT_SECRET=change-this-to-32+char-jwt-secret-key-now!
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Logging (Monolog)
LOG_CHANNEL=bangrondb
LOG_LEVEL=DEBUG
LOG_STDERR=false

# App
QUERY_LOGGING=false
PERFORMANCE_MONITORING=true
APP_DEBUG=true
APP_URL=http://localhost:8000
INERTIA_VERSION=1

# CORS
CORS_ALLOWED_ORIGIN=*

# Auth
AUTH_DB=auth
AUTH_COLLECTION=users