{
  "name": "herdianrony/bangron-studio",
  "description": "Bangron Studio - Dynamic backend platform with Flight PHP + Inertia.js",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "monolog/monolog": "^3.10",
    "firebase/php-jwt": "^7.1",
    "ext-pdo_sqlite": "*",
    "ext-openssl": "*",
    "ext-json": "*",
    "flightphp/core": "^3.18"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "BangronDB\\": "lib/BangronDB/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BangronDB\\Tests\\": "lib/BangronDB/tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"file_exists('storage/data') || mkdir('storage/data',0777,true);\"",
      "@php -r \"file_exists('storage/logs') || mkdir('storage/logs',0777,true);\""
    ],
    "seed": "php seed.php"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
