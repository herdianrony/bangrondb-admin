# BangronDB Environment Configuration
# Copy this file to .env and adjust values as needed.

# Database path. Leave empty to use in-memory storage.
DB_PATH=

# Encryption key.
# Use a strong key with at least 32 characters.
# BangronDB uses AES-256-GCM for document encryption.
ENCRYPTION_KEY=

# Enable query logging (true/false)
QUERY_LOGGING=false

# Enable performance monitoring (true/false)
PERFORMANCE_MONITORING=false
