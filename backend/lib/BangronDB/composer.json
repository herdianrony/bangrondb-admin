{
    "name": "herdianrony/bangrondb",
    "description": "SQLite-based NoSQL document database with MongoDB-like API, encryption, hooks, relationships, and enterprise features",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Rony Herdian",
            "email": "herdianrony@gmail.com"
        }
    ],
    "homepage": "https://github.com/herdianrony/BangronDB",
    "support": {
        "issues": "https://github.com/herdianrony/BangronDB/issues",
        "source": "https://github.com/herdianrony/BangronDB"
    },
    "keywords": [
        "database",
        "nosql",
        "sqlite",
        "mongodb",
        "document-database",
        "json",
        "encryption",
        "php8",
        "php-database",
        "lightweight-database",
        "embedded-database"
    ],
    "autoload": {
        "psr-4": {
            "BangronDB\\": "src/",
            "BangronDB\\Enums\\": "src/Enums/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BangronDB\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.12"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-html=coverage/",
        "lint": "find src/ tests/ -name \"*.php\" -exec php -l {} \\;",
        "analyze": "phpstan analyse --configuration=phpstan.neon --no-progress --memory-limit=512M",
        "clean": "rm -rf vendor/ .phpunit.result.cache coverage/"
    },
    "config": {
        "vendor-dir": "vendor"
    }
}
